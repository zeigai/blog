---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedPosts, postUrl, formatDate } from '../lib/blog';

const posts = await getPublishedPosts();
---
<BaseLayout title="Zeig Blog" description="Insights, updates & market analysis from Zeig.">
  <div class="legal-page">
    <div class="legal-container">
      <h1>Blog</h1>
      <p class="legal-updated">Insights, Updates &amp; Market Analysis</p>

      <section class="legal-section">
        {posts.length === 0 && <p>No posts yet. Check back soon.</p>}
        {posts.map((post) => (
          <article style="margin-bottom: 2.5rem;">
            <p class="legal-updated" style="margin-bottom: 0.25rem;">{formatDate(post.data.pubDate)}</p>
            <h2 style="margin-bottom: 0.5rem;">
              <a href={postUrl(post)}>{post.data.title}</a>
            </h2>
            <p>{post.data.description}</p>
            <a class="legal-back-btn" href={postUrl(post)} style="transform: none;">Read more &rarr;</a>
          </article>
        ))}
      </section>
    </div>
  </div>
</BaseLayout>
